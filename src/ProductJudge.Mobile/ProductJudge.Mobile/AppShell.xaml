<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="ProductJudge.Mobile.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:ProductJudge.Mobile"
    xmlns:features="clr-namespace:ProductJudge.Mobile.Features"
    Shell.FlyoutBehavior="Disabled">

    <ShellContent
        Title="Main"
        ContentTemplate="{DataTemplate local:MainPage}"
        Route="MainPage" />
    
    <ShellContent
        Title="Home"
        ContentTemplate="{DataTemplate features:HomePage}"
        Route="HomePage" />

</Shell>
